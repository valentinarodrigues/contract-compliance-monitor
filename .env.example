# ─── Feature Flags ────────────────────────────────────────────────────────────
# LLM provider: anthropic | openai | mock
LLM_PROVIDER=mock

# Log source: simulated | local_file | cloudwatch | datadog
LOG_SOURCE=simulated

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── OpenAI / OpenAI-compatible (LibertyGPT, Azure, etc.) ────────────────────
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ─── AWS CloudWatch ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
CLOUDWATCH_REGION=us-east-1
CLOUDWATCH_LOG_GROUP=/contract-compliance/logs

# ─── Datadog ──────────────────────────────────────────────────────────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# ─── Local File ───────────────────────────────────────────────────────────────
LOCAL_LOG_DIR=data/sample_logs

# ─── Monitoring ───────────────────────────────────────────────────────────────
ANOMALY_CONTAMINATION=0.05
POLLING_INTERVAL_SECONDS=60
MIN_SAMPLES_FOR_ANOMALY=20

# ─── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ─── Alerting ─────────────────────────────────────────────────────────────────
# Comma-separated: console, slack, email
ALERT_CHANNELS=console
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@company.com
SMTP_PASS=
ALERT_EMAIL_TO=compliance-team@company.com
ALERT_EMAIL_FROM=compliance-monitor@company.com
